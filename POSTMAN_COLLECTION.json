              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "name",
                  "value": "Test User",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "test@example.com",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "password123",
                  "type": "text"
                },
                {
                  "key": "password_confirmation",
                  "value": "password123",
                  "type": "text"
                },
                {
                  "key": "phone",
                  "value": "1234567890",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{v1_base_url}}/register",
              "host": ["{{v1_base_url}}"],
              "path": ["register"]
            }
